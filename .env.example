# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret

# Default Django database (users/auth/admin/sessions)
# If omitted, these fall back to DB_* values below.
DEFAULT_DB_HOST=localhost
DEFAULT_DB_PORT=3306
DEFAULT_DB_NAME=regintel_app
DEFAULT_DB_USER=your_mysql_user
DEFAULT_DB_PASS=your_mysql_password

# Scraper MySQL database
# If SCRAPER_DB_* is omitted, the app falls back to DB_* values for backward compatibility.
SCRAPER_DB_HOST=localhost
SCRAPER_DB_PORT=3306
SCRAPER_DB_NAME=regintel_scraper
SCRAPER_DB_USER=your_mysql_user
SCRAPER_DB_PASS=your_mysql_password

# Shared fallback MySQL database variables
# You can point both databases to the same schema by setting only these values.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=regintel
DB_USER=your_mysql_user
DB_PASS=your_mysql_password

# Gemini API key for summary generation
GEMINI_API_KEY=your_gemini_api_key
